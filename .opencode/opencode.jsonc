{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "model": "half-cabbage/deepseek-v4-flash",
  "agent": {
    "build": {
      "model": "half-cabbage/deepseek-v4-flash",
    },
    "plan": {
      "model": "openai/gpt-5.5",
    },
    "explore": {
      "model": "half-cabbage/deepseek-v4-flash"
    },
    "general": {
      "model": "half-cabbage/deepseek-v4-flash"
    },
    "compaction": {
      "model": "half-cabbage/deepseek-v4-flash"
    },
    "title": {
      "model": "half-cabbage/deepseek-v4-flash"
    },
    "summary": {
      "model": "half-cabbage/deepseek-v4-flash"
    }
  },
  "mcp": {
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
  },
  "lsp": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 5
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "venv/**",
      ".env/**",
      "dist/**",
      "target/**"
    ]
  },
}